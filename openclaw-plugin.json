{
  "name": "doc-genie",
  "version": "0.1.0",
  "description": "Extract black boxes from docs/code, map relationships, discover cross-doc insights",
  "skills": [
    "./skills/genie-extract",
    "./skills/genie-relations",
    "./skills/genie-insights",
    "./skills/genie-report"
  ],
  "commands": {
    "genie-extract": {
      "description": "Extract black boxes from documents",
      "script": "./scripts/cli.py extract"
    },
    "genie-analyze": {
      "description": "Analyze relationships across documents",
      "script": "./scripts/cli.py analyze"
    },
    "genie-report": {
      "description": "Generate analysis report",
      "script": "./scripts/cli.py report"
    }
  }
}
